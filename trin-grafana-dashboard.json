{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=\"trin\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage (RAM)",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"trin\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "gradientMode": "opacity" }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"trin\"}[1m]) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "gradientMode": "opacity" }
        }
      }
    },
    {
      "type": "stat",
      "title": "Peers Conectados (Geral)",
      "gridPos": { "x": 0, "y": 6, "w": 8, "h": 6 },
      "description": "Exemplo de métrica de rede (o nome exato da métrica de peers pode variar conforme a versão do Trin, ajuste se necessário pesquisando 'peer' no painel do Grafana)",
      "targets": [
        {
          "expr": "sum(trin_connected_peers{job=\"trin\"}) or sum(portal_network_connected_peers{job=\"trin\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    }
  ],
  "schemaVersion": 38,
  "title": "Trin Node Overview",
  "uid": "trin-node-01",
  "version": 1,
  "timezone": "browser",
  "refresh": "10s"
}
